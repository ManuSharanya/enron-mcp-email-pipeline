# Copy this file to .env and fill in your values.
# .env is gitignored and must never be committed.

# Anthropic API key — get yours at https://console.anthropic.com
ANTHROPIC_API_KEY=sk-ant-...

# All notification emails are redirected here for testing.
# Set to your Gmail address (the same account used for MCP auth).
NOTIFICATION_OVERRIDE_EMAIL=you@gmail.com

# Max duplicate groups to notify per pipeline run (default: 15).
NOTIFICATION_LIMIT=15
